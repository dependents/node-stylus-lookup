{
  "name": "stylus-lookup",
  "version": "6.1.2",
  "description": "Get the file associated with an imported/required Stylus partial",
  "main": "index.js",
  "files": [
    "bin/cli.js",
    "index.js"
  ],
  "bin": {
    "stylus-lookup": "bin/cli.js"
  },
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "uvu": "uvu test -i fixtures",
    "test": "npm run lint && npm run uvu",
    "test:ci": "c8 npm run uvu"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-stylus-lookup.git"
  },
  "keywords": [
    "stylus",
    "lookup",
    "dependency",
    "partial"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-stylus-lookup/issues"
  },
  "homepage": "https://github.com/dependents/node-stylus-lookup",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "uvu": "^0.5.6",
    "xo": "^2.0.2"
  }
}
