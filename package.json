{
  "name": "stylus-lookup",
  "version": "7.0.0",
  "description": "Get the file associated with an imported/required Stylus partial",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "bin/cli.js",
    "index.js"
  ],
  "bin": {
    "stylus-lookup": "bin/cli.js"
  },
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "vitest": "vitest",
    "test": "npm run lint && vitest run",
    "test:ci": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-stylus-lookup.git"
  },
  "keywords": [
    "stylus",
    "lookup",
    "dependency",
    "partial"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-stylus-lookup/issues"
  },
  "homepage": "https://github.com/dependents/node-stylus-lookup",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "vitest": "^4.1.7",
    "xo": "^2.0.2"
  }
}
